# BBS Firewall - Configuration
# Copy this file to .env and adjust the values for your setup.
# https://github.com/SysopNetwork/BBSFirewall

# =============================================================================
# Network
# =============================================================================

# Port to listen on for incoming telnet connections
LISTEN_PORT=23

# Backend BBS server hostname or IP and port
BACKEND_HOST=127.0.0.1
BACKEND_PORT=23

# Encoding-based routing — route CP437 and UTF-8 clients to separate backend ports
# ENCODING_DETECTION=false
# BACKEND_PORT_CP437=2323
# BACKEND_PORT_UTF8=2423

# =============================================================================
# Connection Limits
# =============================================================================

# Maximum total simultaneous connections from all clients combined
MAX_CONNECTIONS=100

# Maximum simultaneous connections allowed from a single client IP address
# Set to 0 to disable the limit and allow unlimited connections per IP
MAX_CONNECTIONS_PER_IP=3

# Connection timeout in milliseconds (0 to disable)
# Default: 300000 (5 minutes)
CONNECTION_TIMEOUT=300000

# =============================================================================
# Country Blocking (requires GeoIP database — run: npm run setup-geoip)
# =============================================================================

# Comma-separated list of ISO 3166-1 alpha-2 country codes to block
# BLOCKED_COUNTRIES=CN,RU,KP,IR,BY,SY,AF,IQ,PK

# Block connections when the client country cannot be determined
# BLOCK_UNKNOWN_COUNTRIES=false

# =============================================================================
# IP Lists
# =============================================================================

# Path to IP whitelist file — listed IPs bypass ALL firewall rules
WHITELIST_PATH=./whitelist.txt

# Path to IP blocklist file — listed IPs are permanently blocked
BLOCKLIST_PATH=./blocklist.txt

# =============================================================================
# Rate Limiting (flood protection)
# =============================================================================

# Enable or disable rate limiting
RATE_LIMIT_ENABLED=true

# Maximum connection attempts from a single IP within the time window
MAX_CONNECTIONS_PER_WINDOW=10

# Time window for rate limiting in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# How long to block IPs that exceed the rate limit in milliseconds (default: 300000 = 5 minutes)
RATE_LIMIT_BLOCK_DURATION_MS=300000

# =============================================================================
# Web Redirect
# =============================================================================

# Redirect HTTP (port 80) traffic to a configured URL
# Useful for web browsers that visit the firewall's IP address
# Note: HTTPS (port 443) redirect is not supported without a TLS certificate
WEB_REDIRECT_ENABLED=false
WEB_REDIRECT_URL=https://example.com

# =============================================================================
# Logging
# =============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# =============================================================================
# SSH Server (optional — accepts any credentials, proxies to telnet backend)
# Note: Use telnet for Zmodem/Ymodem file transfers; SSH is best for browsing
# =============================================================================

# SSH_ENABLED=false
# SSH_LISTEN_PORT=2222
# SSH_HOST_KEY=./ssh_host_key
# SSH_CIPHERS=aes128-gcm@openssh.com,aes256-gcm@openssh.com,aes128-ctr,aes256-ctr,aes128-cbc,aes256-cbc,3des-cbc
